    "lint:html": "htmlhint \"**/*.html\"",
    "lint:css": "stylelint \"**/*.css\"",
    "format:check": "prettier --check \"**/*.{html,css,md}\"",
    "format": "prettier --write \"**/*.{html,css,md}\"",
    "check": "npm run lint:html && npm run lint:css && npm run format:check",
    "prepare": "husky"
  },
